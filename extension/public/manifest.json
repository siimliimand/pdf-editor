{
  "manifest_version": 3,
  "name": "PDF Editor",
  "description": "PDF Editor",
  "version": "1.0",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": "icon.png"
  },
  "background": {
    "type": "module",
    "service_worker": "service_worker.js"
  },
  "permissions": ["storage"]
}

{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  },
  "permission": {
    "skill": {
      "ob-*": "allow",
      "openspec-*": "allow"
    }
  },
  "model": "openrouter/xiaomi/mimo-v2.5",
  "plugin": [
    "@slkiser/opencode-quota@latest"
  ],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "npx",
        "@colbymchenry/codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true,
      "timeout": 120000
    },
    "agentmemory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@agentmemory/mcp"
      ],
      "env": {
        "AGENTMEMORY_URL": "http://localhost:3111"
      },
      "enabled": true,
      "timeout": 120000
    }
  }
}
